-- PW3 014: Flight operation types, reservation flags, and rank operational permissions
-- Idempotent migration. No destructive operations.

create table if not exists public.flight_operation_types (
  code text primary key,
  label text not null,
  description text null,
  score_mode text not null,
  affects_pilot_position boolean not null default false,
  affects_aircraft_position boolean not null default false,
  affects_economy boolean not null default false,
  affects_ranking boolean not null default false,
  affects_progression boolean not null default false,
  requires_real_aircraft_lock boolean not null default false,
  requires_route boolean not null default false,
  requires_aircraft boolean not null default false,
  requires_payload boolean not null default false,
  requires_simbrief boolean not null default false,
  reservation_expires_minutes integer null,
  is_active boolean not null default true,
  sort_order integer not null default 100,
  created_at timestamptz not null default now(),
  updated_at timestamptz not null default now(),
  constraint flight_operation_types_score_mode_check
    check (score_mode in ('REFERENCE_ONLY','SCHOOL_OFFICIAL','OFFICIAL','MISSION_OFFICIAL','NONE','EVENT_OFFICIAL'))
);

alter table public.flight_operation_types
  add column if not exists label text,
  add column if not exists description text,
  add column if not exists score_mode text,
  add column if not exists affects_pilot_position boolean not null default false,
  add column if not exists affects_aircraft_position boolean not null default false,
  add column if not exists affects_economy boolean not null default false,
  add column if not exists affects_ranking boolean not null default false,
  add column if not exists affects_progression boolean not null default false,
  add column if not exists requires_real_aircraft_lock boolean not null default false,
  add column if not exists requires_route boolean not null default false,
  add column if not exists requires_aircraft boolean not null default false,
  add column if not exists requires_payload boolean not null default false,
  add column if not exists requires_simbrief boolean not null default false,
  add column if not exists reservation_expires_minutes integer,
  add column if not exists is_active boolean not null default true,
  add column if not exists sort_order integer not null default 100,
  add column if not exists created_at timestamptz not null default now(),
  add column if not exists updated_at timestamptz not null default now();

insert into public.flight_operation_types (
  code, label, description, score_mode,
  affects_pilot_position, affects_aircraft_position, affects_economy, affects_ranking, affects_progression,
  requires_real_aircraft_lock, requires_route, requires_aircraft, requires_payload, requires_simbrief,
  reservation_expires_minutes, is_active, sort_order, updated_at
)
values
('TRAINING_FREE','Entrenamiento libre','Práctica referencial sin efectos operacionales oficiales.','REFERENCE_ONLY',false,false,false,false,false,false,false,true,false,false,15,true,10,now()),
('SCHOOL_OFFICIAL_ROUTE','Ruta oficial','Ruta oficial de escuela/academia. Cuenta para progresión, sin economía comercial.','SCHOOL_OFFICIAL',true,true,false,true,true,true,true,true,false,true,15,true,20,now()),
('COMMERCIAL_OFFICIAL_ROUTE','Ruta oficial','Ruta oficial comercial de aerolínea.','OFFICIAL',true,true,true,true,true,true,true,true,true,true,15,true,30,now()),
('CHARTER_OFFICIAL','Charter','Operación oficial solicitada.','OFFICIAL',true,true,true,true,true,true,false,true,true,true,15,true,40,now()),
('CARGO_OFFICIAL','Carga','Operación oficial de carga.','OFFICIAL',true,true,true,true,true,true,true,true,true,true,15,true,50,now()),
('AIRCRAFT_TRANSFER','Traslado de aeronave','Misión especial para mover una aeronave real de la flota.','MISSION_OFFICIAL',true,true,false,true,true,true,false,true,false,true,15,true,60,now()),
('PILOT_REPOSITION','Reposicionamiento del piloto','Mueve solo la ubicación operacional del piloto. No mueve aeronaves.','NONE',true,false,false,false,false,false,false,false,false,false,null,true,70,now()),
('EVENT_TOUR','Evento / Tour','Evento operativo especial.','EVENT_OFFICIAL',false,false,false,true,false,false,true,true,false,true,15,true,80,now())
on conflict (code) do update set
  label = excluded.label,
  description = excluded.description,
  score_mode = excluded.score_mode,
  affects_pilot_position = excluded.affects_pilot_position,
  affects_aircraft_position = excluded.affects_aircraft_position,
  affects_economy = excluded.affects_economy,
  affects_ranking = excluded.affects_ranking,
  affects_progression = excluded.affects_progression,
  requires_real_aircraft_lock = excluded.requires_real_aircraft_lock,
  requires_route = excluded.requires_route,
  requires_aircraft = excluded.requires_aircraft,
  requires_payload = excluded.requires_payload,
  requires_simbrief = excluded.requires_simbrief,
  reservation_expires_minutes = excluded.reservation_expires_minutes,
  is_active = excluded.is_active,
  sort_order = excluded.sort_order,
  updated_at = now();

alter table public.pilot_ranks
  add column if not exists allows_training_free boolean not null default true,
  add column if not exists allows_school_routes boolean not null default false,
  add column if not exists allows_commercial_routes boolean not null default false,
  add column if not exists allows_aircraft_transfer boolean not null default false,
  add column if not exists allows_pilot_reposition boolean not null default true;

-- Compatibility sync with legacy columns (keep both sets)
update public.pilot_ranks
set
  allows_training_free = coalesce(allows_training_free, allows_training, true),
  allows_school_routes = coalesce(allows_school_routes, false),
  allows_commercial_routes = coalesce(allows_commercial_routes, allows_passenger, false),
  allows_aircraft_transfer = coalesce(allows_aircraft_transfer, allows_positioning, false),
  allows_pilot_reposition = coalesce(allows_pilot_reposition, true);

-- CADET strict policy
update public.pilot_ranks
set
  allows_training_free = true,
  allows_school_routes = true,
  allows_commercial_routes = false,
  allows_charter = false,
  allows_cargo = false,
  allows_aircraft_transfer = false,
  allows_pilot_reposition = true,
  allows_international = false,
  allows_oceanic = false,
  allows_long_range = false,
  allows_widebody = false
where rank_code = 'CADET';

-- SECOND_OFFICER baseline (preserve any stronger existing permission except explicit training/school/reposition)
update public.pilot_ranks
set
  allows_training_free = true,
  allows_school_routes = true,
  allows_aircraft_transfer = (allows_aircraft_transfer or true),
  allows_pilot_reposition = true
where rank_code = 'SECOND_OFFICER';

-- FIRST_OFFICER and above: official commercial baseline on
update public.pilot_ranks
set
  allows_training_free = true,
  allows_school_routes = true,
  allows_commercial_routes = true,
  allows_aircraft_transfer = true,
  allows_pilot_reposition = true,
  allows_charter = (allows_charter or true),
  allows_cargo = (allows_cargo or true)
where rank_code in (
  'FIRST_OFFICER','SENIOR_FIRST_OFFICER','CAPTAIN','SENIOR_CAPTAIN','TRAINING_CAPTAIN','COMMANDER','SENIOR_COMMANDER','CHIEF_PILOT'
);

create table if not exists public.flight_reservation_status_log (
  id uuid primary key default gen_random_uuid(),
  reservation_id uuid not null,
  previous_status text null,
  new_status text not null,
  reason text null,
  actor_type text not null default 'system',
  actor_user_id uuid null,
  metadata jsonb not null default '{}'::jsonb,
  created_at timestamptz not null default now()
);

create index if not exists flight_reservation_status_log_reservation_id_idx
  on public.flight_reservation_status_log (reservation_id);
create index if not exists flight_reservation_status_log_new_status_idx
  on public.flight_reservation_status_log (new_status);
create index if not exists flight_reservation_status_log_created_at_idx
  on public.flight_reservation_status_log (created_at);

-- Normalize reservation tables if they exist
DO $$
DECLARE
  t text;
BEGIN
  FOREACH t IN ARRAY ARRAY['training_reservations','flight_reservations','dispatch_reservations']
  LOOP
    IF to_regclass('public.' || t) IS NOT NULL THEN
      EXECUTE format('alter table public.%I
        add column if not exists operation_type text,
        add column if not exists score_mode text,
        add column if not exists affects_pilot_position boolean not null default false,
        add column if not exists affects_aircraft_position boolean not null default false,
        add column if not exists affects_economy boolean not null default false,
        add column if not exists affects_ranking boolean not null default false,
        add column if not exists affects_progression boolean not null default false,
        add column if not exists requires_real_aircraft_lock boolean not null default false,
        add column if not exists reservation_expires_at timestamptz,
        add column if not exists dispatch_token_hash text,
        add column if not exists prepared_acars_payload jsonb,
        add column if not exists status text,
        add column if not exists acars_status text,
        add column if not exists acars_ready_at timestamptz,
        add column if not exists acars_claimed_at timestamptz', t);

      EXECUTE format($f$
        update public.%I
        set
          operation_type = 'TRAINING_FREE',
          score_mode = 'REFERENCE_ONLY',
          affects_pilot_position = false,
          affects_aircraft_position = false,
          affects_economy = false,
          affects_ranking = false,
          affects_progression = false,
          requires_real_aircraft_lock = false
        where operation_type = 'TRAINING_FREE'
      $f$, t);
    END IF;
  END LOOP;
END$$;

create or replace view public.pw_flight_operation_rules as
select
  code,
  label,
  score_mode,
  affects_pilot_position,
  affects_aircraft_position,
  affects_economy,
  affects_ranking,
  affects_progression,
  requires_real_aircraft_lock,
  requires_route,
  requires_aircraft,
  requires_payload,
  requires_simbrief,
  reservation_expires_minutes,
  is_active,
  sort_order
from public.flight_operation_types
order by sort_order asc, code asc;
